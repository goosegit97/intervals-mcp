# intervals-mcp local development configuration.
# Copy to .env (git-ignored) and fill in real values. Production sets these as
# real environment variables via the systemd EnvironmentFile (see ansible/).

# --- Transport ---------------------------------------------------------------
# Unset INTERVALS_LISTEN_ADDR to serve over stdio (local MCP clients, no auth).
# Set it (e.g. 127.0.0.1:8081) to serve Streamable HTTP behind a bearer token.
# INTERVALS_LISTEN_ADDR=127.0.0.1:8081

# Required in HTTP mode: the shared bearer token every request must present.
# Generate a long random value, e.g.  openssl rand -hex 32
# MCP_BEARER_TOKEN=

# --- Intervals.icu credentials ----------------------------------------------
# API key (HTTP Basic password; username is literally "API_KEY").
INTERVALS_API_KEY=
# Athlete id, e.g. i123456 ("0" also works for the authenticated athlete).
INTERVALS_ATHLETE_ID=
