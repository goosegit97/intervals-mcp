# Managed by Ansible (roles/caddy).
# Single-user intervals MCP: the whole domain proxies to the intervals backend.
{
{% if caddy_acme_email | length > 0 %}
    email {{ caddy_acme_email }}
{% endif %}
}

{{ app_domain }} {
    encode gzip

    # intervals MCP. Rewrite Host to the upstream so the MCP SDK's localhost
    # DNS-rebinding protection accepts the proxied request (it rejects a
    # localhost listener receiving a non-localhost Host header).
    reverse_proxy 127.0.0.1:8081 {
        header_up Host {upstream_hostport}
    }
}
